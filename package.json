{
  "name": "nestjs-swagger-mcp-repo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "build:adapter": "npm --prefix packages/adapter run build",
    "dev:api": "npm --prefix examples/nest-app run start:dev",
    "dev:react": "npm --prefix examples/react-client run dev"
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "@eslint/js": "^9.15.0",
    "typescript-eslint": "^8.15.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "globals": "^15.12.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-config-prettier": "^9.1.0"
  }
}