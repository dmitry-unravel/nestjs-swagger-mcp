{
  "name": "@reliqio/nestjs-swagger-mcp",
  "version": "0.1.3",
  "author": "Gilad Glasberg (https://github.com/giladg1)",
  "description": "NestJS module that auto-exposes your REST API as MCP tools via a single /mcp endpoint.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "test": "jest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reliqio/nestjs-swagger-mcp.git"
  },
  "keywords": ["nestjs", "mcp", "model-context-protocol", "openapi", "swagger", "llm", "tools", "json-rpc"],
  "license": "MIT",
  "engines": { "node": ">=18" },
  "peerDependencies": {
    "@nestjs/common": "^10",
    "@nestjs/core": "^10",
    "@nestjs/swagger": "^7"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1",
    "openapi3-ts": "^4.5.0",
    "@types/node": "^20.14.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0",
    "reflect-metadata": "^0.2.2",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "semantic-release": "^24.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0"
  }
}
